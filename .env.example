# Backend local (.NET)
# ASP.NET environment
ASPNETCORE_ENVIRONMENT=Development

# En Development, Program.cs usa:
# - DevelopmentProductionConnection cuando DatabaseTarget=Production
# - DevelopmentLocalConnection cuando DatabaseTarget=Local
DatabaseTarget=Production

# Opcional: forzar cadena de conexión por variable de entorno
# (sobrescribe appsettings por convención de .NET)
# ConnectionStrings__DevelopmentProductionConnection=Server=...;Database=...;User Id=...;Password=...;TrustServerCertificate=True;Encrypt=True;
# ConnectionStrings__DefaultConnection=Server=...;Database=...;User Id=...;Password=...;TrustServerCertificate=True;Encrypt=True;

# Opcional: Azure Graph en entornos donde aplique
# AzureGraph__TenantId=
# AzureGraph__ClientId=
# AzureGraph__ClientSecret=
# AzureGraph__Scope=https://graph.microsoft.com/.default
# AzureGraph__GraphBaseUrl=https://graph.microsoft.com/v1.0
